# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# -----------------------------------------------
# Soundscape additions
# -----------------------------------------------

# Environment / secrets — never commit real values
.env
.env.*
!.env.example

# Android local machine config — paths are specific to each machine
android/local.properties
android/.gradle/

# Android signing key — if you add one later, never commit it
android/key.properties
android/app/*.jks
android/app/*.keystore

# iOS generated config — machine-specific
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/.symlinks/
ios/Pods/

# Flutter plugin generated file — regenerated on flutter pub get
.flutter-plugins

# Scratch/backup files created during development
lib.bk/
lib.zip
*.bk
*.zip